<manifest xmlns:android="http://schemas.android.com/apk/res/android" package="com.jeramyadams.aiscreenreader">
    <application android:allowBackup="true" android:label="AI Screen Reader">
        <service android:name=".AIScreenReaderService"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data android:name="android.accessibilityservice" android:resource="@xml/accessibility_service_config" />
        </service>
    </application>
</manifest>
